# API Keys (optional but recommended)
# Get OMDB API key from: http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Get Last.fm API key from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# Database URL (defaults to SQLite in data directory)
# DATABASE_URL=sqlite:///./data/media_tracker.db

# Frontend API Base URL
# For Docker internal network (default):
# API_BASE_URL=http://backend:8000
# For external network access from other devices via IP:
# API_BASE_URL=http://<your-imac-ip-address>:8000
# For external network access from other devices via hostname:
# API_BASE_URL=http://<your-hostname>.local:8000
#   (e.g., http://mediatracker.local:8000 or http://MacBook-Pro.local:8000)
API_BASE_URL=http://backend:8000

# React Frontend API Base URL (used during build)
# For Docker internal network (default):
# VITE_API_BASE_URL=http://localhost:8000
# For external network access from other devices via IP:
# VITE_API_BASE_URL=http://<your-imac-ip-address>:8000
# For external network access from other devices via hostname:
# VITE_API_BASE_URL=http://<your-hostname>.local:8000
#   (e.g., http://mediatracker.local:8000 or http://MacBook-Pro.local:8000)
VITE_API_BASE_URL=http://localhost:8000

